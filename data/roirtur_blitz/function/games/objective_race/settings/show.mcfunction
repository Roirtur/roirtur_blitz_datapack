tellraw @s [{"text":"Objective Race settings","color":"gold"}]
execute if score #mode orace_mode matches 0 run tellraw @s [{"text":"Mode: shared_evolving","color":"yellow"}]
execute if score #mode orace_mode matches 1 run tellraw @s [{"text":"Mode: objective_list","color":"yellow"}]
tellraw @s [{"text":"Target count: ","color":"yellow"},{"score":{"name":"#target","objective":"orace_target"},"color":"aqua"}]
execute if score #difficulty orace_diff matches 0 run tellraw @s [{"text":"Difficulty preset: easy_only","color":"yellow"}]
execute if score #difficulty orace_diff matches 1 run tellraw @s [{"text":"Difficulty preset: balanced","color":"yellow"}]
execute if score #difficulty orace_diff matches 2 run tellraw @s [{"text":"Difficulty preset: hardcore","color":"yellow"}]
execute if score #difficulty orace_diff matches 3 run tellraw @s [{"text":"Difficulty preset: chaos","color":"yellow"}]
execute if score #keepinv_setting orace_keep matches 1 run tellraw @s [{"text":"Keep inventory: on","color":"yellow"}]
execute if score #keepinv_setting orace_keep matches 0 run tellraw @s [{"text":"Keep inventory: off","color":"yellow"}]
execute if score #allow_solo orace_flag matches 1 run tellraw @s [{"text":"Solo testing: enabled","color":"yellow"}]
execute if score #allow_solo orace_flag matches 0 run tellraw @s [{"text":"Solo testing: disabled","color":"yellow"}]
execute if score #round_time orace_round matches 0 run tellraw @s [{"text":"Round time: no limit","color":"yellow"}]
execute if score #round_time orace_round matches 1.. run tellraw @s [{"text":"Round time (seconds): ","color":"yellow"},{"score":{"name":"#round_time","objective":"orace_round"},"color":"aqua"}]
execute if score #powerups_enabled orace_pow matches 0 run tellraw @s [{"text":"Powerups: disabled in v1","color":"yellow"}]
execute if entity @e[type=marker,tag=orace.lobby,limit=1] run tellraw @s [{"text":"Lobby marker: set","color":"green"}]
execute unless entity @e[type=marker,tag=orace.lobby,limit=1] run tellraw @s [{"text":"Lobby marker: not set","color":"red"}]

